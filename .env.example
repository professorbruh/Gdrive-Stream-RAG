# Copy this file to .env and fill in your values

# ── HuggingFace ──────────────────────────────────────
HF_TOKEN=hf_your_token_here

# ── LLM Settings ─────────────────────────────────────
# LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# LLM_MODE=hf_api
# LLM_LOAD_IN_4BIT=true
# LLM_MAX_NEW_TOKENS=1024
# LLM_TEMPERATURE=0.3

# ── Retrieval ────────────────────────────────────────
# RETRIEVAL_TOP_K=6

# ── Web Server ───────────────────────────────────────
# WEB_HOST=0.0.0.0
# WEB_PORT=8000

# ── MCP Transport ────────────────────────────────────
# MCP_TRANSPORT=stdio
# MCP_SSE_PORT=8001
